---
interface Props {
  title: string;
  description: string;
  href: string;
  stars?: number;
  language?: string;
  topics?: string[];
}

const {
  title,
  description,
  href,
  stars = 0,
  language = 'Unknown',
  topics = [],
} = Astro.props;
---

<li class="rounded-lg border border-[--color-border] bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-lg font-semibold text-[--color-primary] hover:underline"
      >
        {title}
      </a>
      <p class="mt-1 text-sm text-[--color-text-muted] line-clamp-2">
        {description}
      </p>
      {topics.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2">
          {topics.slice(0, 5).map((topic: string) => (
            <li
              class="rounded-full bg-[--color-surface] px-2.5 py-0.5 text-xs font-medium text-[--color-text-muted]"
            >
              {topic}
            </li>
          ))}
        </ul>
      )}
    </div>
    <div class="flex flex-col items-end gap-1 text-sm text-[--color-text-muted]">
      {stars > 0 && (
        <span class="flex items-center gap-1">
          <svg
            aria-hidden="true"
            height="16"
            viewBox="0 0 16 16"
            version="1.1"
            width="16"
            fill="currentColor"
          >
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
          </svg>
          {stars.toLocaleString()}
        </span>
      )}
      <span class="flex items-center gap-1">
        <span
          aria-hidden="true"
          class="inline-block h-3 w-3 rounded-full"
          style="background-color: var(--color-primary)"
        ></span>
        {language}
      </span>
    </div>
  </div>
</li>
