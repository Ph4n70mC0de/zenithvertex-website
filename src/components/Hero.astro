---
const {
  tagline = 'Building the future of web, AI, and clean architecture.',
  ctaHref = 'https://github.com/ZenithVertex',
  ctaLabel = 'Explore our work',
} = Astro.props;
---

<section class="relative overflow-hidden bg-[--color-surface]">
  <div class="mx-auto max-w-5xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-[--color-text] sm:text-5xl">
        ZenithVertex
      </h1>
      <p class="mt-4 text-lg text-[--color-text-muted]">{tagline}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg bg-[--color-primary] px-6 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-[--color-primary-dark]"
        >
          {ctaLabel}
        </a>
        <a
          href="/projects"
          class="rounded-lg border border-[--color-border] bg-white px-6 py-3 font-semibold text-[--color-text] shadow-sm transition-colors hover:bg-[--color-surface]"
        >
          View projects
        </a>
      </div>
    </div>
  </div>
</section>
