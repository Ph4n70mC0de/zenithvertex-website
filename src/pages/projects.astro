---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchRepos } from '../lib/github';

const repos: Record<string, unknown>[] = await fetchRepos();
---

<BaseLayout title="Projects" description="All public repositories from ZenithVertex.">
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-[--color-text]">All projects</h1>
    <p class="mt-2 text-[--color-text-muted]">
      Live data from the GitHub API. Updated on every deploy.
    </p>
    {repos.length === 0 && (
      <p class="mt-8 text-[--color-text-muted]">
        No repositories found for this organization yet.
      </p>
    )}
    {repos.length > 0 && (
      <ul class="mt-8 grid gap-6 sm:grid-cols-2">
        {repos.map((repo) => (
          <ProjectCard
            title={(repo.name as string) ?? 'Untitled'}
            description={(repo.description as string) || 'No description provided.'}
            href={(repo.html_url as string) ?? '#'}
            stars={(repo.stargazers_count as number) ?? 0}
            language={(repo.language as string) ?? 'Unknown'}
            topics={((repo.topics as string[]) ?? [])}
          />
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
