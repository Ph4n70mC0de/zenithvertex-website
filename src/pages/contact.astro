---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with ZenithVertex."
>
  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-[--color-text]">Contact</h1>
    <p class="mt-2 text-[--color-text-muted]">
      We read every message, but GitHub Discussions is the fastest way to reach the team.
    </p>

    <div class="mt-8 rounded-lg border border-[--color-border] bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-[--color-text]">GitHub Discussions</h2>
      <p class="mt-2 text-sm text-[--color-text-muted]">
        Ask questions, propose ideas, and connect with the community.
        This is our preferred channel for support and collaboration.
      </p>
      <a
        href="https://github.com/ZenithVertex/discussions"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block rounded-lg bg-[--color-primary] px-5 py-3 font-semibold text-white shadow-sm hover:bg-[--color-primary-dark]"
      >
        Open Discussions
      </a>
    </div>

    <div class="mt-8 rounded-lg border border-[--color-border] bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-[--color-text]">Email</h2>
      <p class="mt-2 text-sm text-[--color-text-muted]">
        For private inquiries, reach us directly.
      </p>
      <a
        href="mailto:contact@zenithvertex.org"
        class="mt-4 inline-block text-[--color-primary] hover:underline"
      >
        contact@zenithvertex.org
      </a>
    </div>

    <p class="mt-8 text-sm text-[--color-text-muted]">
      Prefer forms? Replace the card above with a Formspree or Web3Forms embed when you have an endpoint.
    </p>
  </section>
</BaseLayout>
